# ---------------------------------------------------------------------------
# SignalWatch environment configuration template.
# Copy to `.env` and fill in values for local development.
# NEVER commit a real `.env` file — it is gitignored by default.
# ---------------------------------------------------------------------------

# --- Database (local dev default, see scripts/dev-services.sh) -------------
DATABASE_URL="postgresql://signalwatch:localdevpass@localhost:5433/signalwatch"

# --- Redis / background jobs (local dev default) ----------------------------
REDIS_URL="redis://localhost:6380"

# --- Auth --------------------------------------------------------------------
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-random-32-byte-base64-secret"
NEXTAUTH_URL="http://localhost:3000"

# --- AI analysis (Anthropic Claude) ------------------------------------------
# If unset, SignalWatch automatically falls back to a deterministic, clearly
# labelled MOCK analysis engine. No mock output is ever presented as if it
# came from Claude. Set this to enable real AI analysis.
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-5"

# --- Optional licensed news API (Tier 1 adapter) -----------------------------
# If unset, the NewsAPI-or-comparable adapter reports authStatus="missing"
# and stays hidden/disabled in the UI rather than being silently mocked.
NEWSAPI_KEY=""

# --- Optional outbound alert delivery ----------------------------------------
# SMTP for email alert delivery. If unset, email alerts are logged as
# "not delivered - no SMTP configured" instead of silently failing.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="SignalWatch Alerts <alerts@example.com>"

# Slack / Microsoft Teams incoming webhook URLs are configured per AlertRule
# in the app UI, not here (each project can have its own webhook).

# --- Misc ---------------------------------------------------------------------
NODE_ENV="development"
